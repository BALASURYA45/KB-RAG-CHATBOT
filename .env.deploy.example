# Copy this file to .env on the deployment server and update the values.

POSTGRES_DB=kb_support_assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-postgres-password

ADMIN_API_KEY=change-this-long-random-admin-key

# Public URL where users open the frontend.
FRONTEND_ORIGIN=http://your-server-ip:5173

# URL reachable from the backend container.
# If Ollama runs on the Docker host, keep host.docker.internal for Docker Desktop.
# On Linux servers, you may need http://172.17.0.1:11434 or run Ollama in Docker.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Browser-facing backend URL baked into the frontend build.
VITE_API_BASE_URL=http://your-server-ip:4000
